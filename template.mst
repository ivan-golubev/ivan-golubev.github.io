<div class="col-md-6 col-sm-6">
    <article class="blog-teaser">
        <header>
            <img src="{{img_src}}" alt="A Cat">
            <h3><a href="blog-detail.html">{{title}}</a></h3>
            <span class="meta">{{name_date}}</span>
            <hr>
        </header>
        <div class="body">
            {{body_text}}
        </div>
        <div class="clearfix">
            <a href="blog-detail.html" class="btn btn-primary">Read more</a>
        </div>
    </article>	
</div>